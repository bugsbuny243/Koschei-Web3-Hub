{
  "name": "@koschei/arvis-sdk",
  "version": "0.1.0",
  "description": "TypeScript client for Koschei ARVIS Solana risk intelligence APIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "arvis-verdict": "./bin/arvis-verdict.mjs"
  },
  "files": ["dist", "bin", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepack": "npm run check && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "license": "MIT"
}
