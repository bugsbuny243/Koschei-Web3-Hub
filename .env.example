APP_NAME=Koschei Web3 Hub
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGIN=http://localhost:3000

ADMIN_EMAIL=
ADMIN_PASSWORD=
# Standalone Go member-auth service. Keep AUTH_API_URL server-side.
AUTH_API_URL=http://localhost:8080
USER_SESSION_SECRET=

# Neon Auth. EXPO_PUBLIC_NEON_AUTH_URL is the existing public client URL; the others are server-side.
EXPO_PUBLIC_NEON_AUTH_URL=
NEON_AUTH_BASE_URL=
NEON_AUTH_ISSUER=
NEON_AUTH_JWKS_URL=
AI_PROVIDER=together
AI_ENABLED=false
TOGETHER_API_KEY=
TOGETHER_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507-tput

WEB3_PROVIDER=alchemy
ALCHEMY_API_KEY=

SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_NETWORK=devnet
SOLANA_RPC_URL=
BASE_NETWORK=sepolia
NEXT_PUBLIC_BASE_NETWORK=sepolia
ARBITRUM_NETWORK=sepolia
NEXT_PUBLIC_ARBITRUM_NETWORK=sepolia
POLYGON_NETWORK=amoy
NEXT_PUBLIC_POLYGON_NETWORK=amoy
OPTIMISM_NETWORK=sepolia
NEXT_PUBLIC_OPTIMISM_NETWORK=sepolia
ETHEREUM_NETWORK=sepolia
NEXT_PUBLIC_ETHEREUM_NETWORK=sepolia
# Optional explicit server-side RPC overrides
BASE_RPC_URL=
ARBITRUM_RPC_URL=
POLYGON_RPC_URL=
OPTIMISM_RPC_URL=
ETHEREUM_RPC_URL=

# Server-side Neon Postgres connection string. Never expose with NEXT_PUBLIC_.
DATABASE_URL=
DIRECT_DATABASE_URL=

FEATURE_SOLANA=true
FEATURE_BASE=true
FEATURE_ARBITRUM=true
FEATURE_POLYGON=true
FEATURE_OPTIMISM=true
FEATURE_ETHEREUM=true
FEATURE_RISK_SCANNER=true
FEATURE_METADATA_STUDIO=true
FEATURE_GAME_ASSET_BRIDGE=true
FEATURE_LAUNCH_PAGE_BUILDER=true
FEATURE_GRANT_OS=false
