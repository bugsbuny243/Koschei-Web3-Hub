PORT=8080
# Required on Railway/production: disables local-only debug routes and enables production checks.
APP_ENV=production
STATIC_DIR=public
DATABASE_URL=
# Render + lib/pq must use the Neon Direct connection URL. Do not use the Neon pooled/pooler URL; pooled prepared statement routing can cause "unnamed prepared statement does not exist" errors.
NEON_AUTH_BASE_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth
EXPO_PUBLIC_NEON_AUTH_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth
NEON_AUTH_ISSUER=https://YOUR_NEON_AUTH_HOST
NEON_AUTH_JWKS_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth/.well-known/jwks.json
# Optional: override Neon callback state signing. If empty, the app reuses existing secrets such as USER_SESSION_SECRET, OWNER_SECRET, ADMIN_PASSWORD, or DATABASE_URL.
NEON_AUTH_STATE_SECRET=
USER_SESSION_SECRET=
CORS_ORIGIN=https://tradepigloball.co
# Deprecated compatibility alias. Prefer CORS_ORIGIN.
CORS_ALLOWED_ORIGIN=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ALCHEMY_API_KEY=
TOGETHER_API_KEY=
TOGETHER_MODEL=

# Pay-per-tool foundation remains disabled unless explicitly enabled.
KOSCHEI_X402_ENABLED=false

# Phase 1 enterprise architecture foundation
DATABASE_READ_URL=
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_SECONDS=1800
CACHE_ENABLED=true
CACHE_KEY_PREFIX=koschei
REDIS_URL=
REDIS_TLS=false
NATS_URL=
NATS_SUBJECT_PREFIX=koschei.web3
WEB3_WORKER_ENABLED=false
WEB3_WORKER_CONCURRENCY=8
WEB3_JOB_TIMEOUT_SECONDS=60
WEB3_JOB_MAX_ATTEMPTS=3

# Tier 1 public-good module integrations
JITO_BUNDLE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_AUTH_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
WHITEHAT_ALERT_ADDRESSES=

# Paddle B2B SaaS billing (Render environment values in production)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=production
PADDLE_CHECKOUT_URL=https://tradepigloball.co/pricing
PADDLE_STARTER_PRODUCT_ID=pro_01ktvdfyd63cnr7x1wp7w1dvhb
PADDLE_PROFESSIONAL_PRODUCT_ID=pri_01ktvhhg4z91j3wjrts1kzswhm
PADDLE_ENTERPRISE_PRODUCT_ID=pro_01ktvhmzq5q9gs0h71pzyy97b2
