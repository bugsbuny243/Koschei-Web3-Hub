# === App ===
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_NAME=Koscei Bridge

# === Chains / RPC (Alchemy) ===
ALCHEMY_API_KEY=your_alchemy_api_key
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your_alchemy_api_key
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your_alchemy_api_key
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# === Agent / LLM (Groq) ===
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# === WalletConnect ===
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# === Pinata / IPFS ===
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY_URL=https://your-gateway.mypinata.cloud

# === Optional price feeds ===
PYTH_HERMES_URL=https://hermes.pyth.network
CHAINLINK_FEED_REGISTRY=0x47Fb2585D2C56Fe188D0E6ec628a38b74fCeeeDf

# === Auth / DB ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/koscei_bridge
AUTH_SECRET=replace_with_a_long_random_string
NEXTAUTH_URL=http://localhost:3000
