PORT=8080
APP_ENV=production
APP_NAME=Koschei Web3 Hub
STATIC_DIR=public
NEXT_PUBLIC_APP_URL=https://tradepigloball.co
DATABASE_URL=

# Neon Auth - do not remove or replace; Koschei login/session flows depend on Neon Auth.
NEON_AUTH_BASE_URL=
NEON_AUTH_ISSUER=
NEON_AUTH_JWKS_URL=
EXPO_PUBLIC_NEON_AUTH_URL=
USER_SESSION_SECRET=

# Admin panel
ADMIN_EMAIL=
ADMIN_PASSWORD=
CORS_ALLOWED_ORIGIN=https://tradepigloball.co

# Web3 providers / networks
WEB3_PROVIDER=alchemy
ALCHEMY_API_KEY=
SOLANA_RPC_URL=
SOLANA_NETWORK=devnet
ETHEREUM_NETWORK=sepolia
ARBITRUM_NETWORK=sepolia
BASE_NETWORK=sepolia
OPTIMISM_NETWORK=sepolia
POLYGON_NETWORK=amoy
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_ETHEREUM_NETWORK=sepolia
NEXT_PUBLIC_ARBITRUM_NETWORK=sepolia
NEXT_PUBLIC_BASE_NETWORK=sepolia
NEXT_PUBLIC_OPTIMISM_NETWORK=sepolia
NEXT_PUBLIC_POLYGON_NETWORK=amoy

# Active production module flags (only these six user modules are active)
FEATURE_TX_DECODER=true
FEATURE_TOKEN_SCANNER=true
FEATURE_WALLET_SCORE=true
FEATURE_RISK_SCANNER=true
FEATURE_PORTFOLIO_TRACKER=true
FEATURE_PROJECT_RADAR=true
FEATURE_SOLANA=true
FEATURE_ETHEREUM=true
FEATURE_ARBITRUM=true
FEATURE_BASE=true
FEATURE_OPTIMISM=true
FEATURE_POLYGON=true

# AI provider settings for admin Koschei Chat and supported analysis helpers.
AI_ENABLED=false
AI_PROVIDER=together
TOGETHER_AI_ENABLED=true
TOGETHER_API_KEY=
TOGETHER_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507-tput

# Optional platform integrations
GOOGLE_APPLICATION_CREDENTIALS_JSON=
ANDROID_PLAY_PACKAGE_NAME=

# Pay-per-tool foundation remains disabled unless explicitly enabled.
KOSCHEI_X402_ENABLED=false
