# Application
PORT=10000
APP_ENV=production
STATIC_DIR=public
PUBLIC_APP_URL=https://tradepigloball.co
CORS_ORIGIN=https://tradepigloball.co,https://www.tradepigloball.co

# Required production security
# Generate strong, independent random values. Do not reuse database or provider credentials.
API_KEY_PEPPER=
USER_SESSION_SECRET=

# Neon Postgres
# Use the connection URL supported by the deployed driver and Neon configuration.
DATABASE_URL=
DATABASE_READ_URL=
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_SECONDS=1800

# Neon Auth
NEON_AUTH_BASE_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth
EXPO_PUBLIC_NEON_AUTH_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth
NEON_AUTH_ISSUER=https://YOUR_NEON_AUTH_HOST
NEON_AUTH_JWKS_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth/.well-known/jwks.json
NEON_AUTH_STATE_SECRET=

# Owner access
OWNER_SECRET=
OWNER_WALLET=

# Legacy owner aliases; do not use for new installations.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Canonical Solana RPC
# ARVIS resolves one canonical SOLANA_RPC_URL at boot.
# Resolution priority:
# SOLANA_RPC_URL -> provider URL -> ALCHEMY_API_KEY -> public mainnet fallback.
SOLANA_RPC_URL=
ALCHEMY_SOLANA_RPC_URL=
HELIUS_SOLANA_RPC_URL=
QUICKNODE_SOLANA_RPC_URL=
ALCHEMY_API_KEY=
SOLANA_WSS_URL=
ALCHEMY_SOLANA_WSS_URL=
HELIUS_SOLANA_WSS_URL=
QUICKNODE_SOLANA_WSS_URL=
# Smooth process-wide RPC bursts and pause every worker after provider capacity responses.
SOLANA_RPC_MIN_INTERVAL_MS=500
SOLANA_RPC_MAX_429_RETRIES=2
SOLANA_RPC_429_BACKOFF_MS=1000
SOLANA_RPC_429_COOLDOWN_SECONDS=120
SOLANA_RPC_BUDGET_ENABLED=false
SOLANA_RPC_BUDGET_MAX_REQUESTS=900
SOLANA_RPC_BUDGET_WINDOW_SECONDS=3600

# ARVIS live radar
KOSCHEI_AUTO_RADAR_ENABLED=1
KOSCHEI_SOLANA_WATCH_MODE=stream
RADAR_STREAM_ENABLED=1
ARVIS_HEARTBEAT_DISABLED=false
ARVIS_STREAM_VERDICT_DISABLED=false
ARVIS_HEARTBEAT_SECONDS=20
ARVIS_STREAM_VERDICT_SECONDS=12
RAYDIUM_PROGRAM_ID=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8
PUMP_FUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# Optional AI explanation layer
# AI explanations do not override evidence or signed verdicts.
TOGETHER_API_KEY=
TOGETHER_MODEL=
TOGETHER_AI_ENABLED=0

# Cache and jobs
CACHE_ENABLED=true
CACHE_KEY_PREFIX=koschei
REDIS_URL=
REDIS_TLS=false
NATS_URL=
NATS_SUBJECT_PREFIX=koschei.web3
WEB3_WORKER_ENABLED=false
WEB3_WORKER_CONCURRENCY=8
WEB3_JOB_TIMEOUT_SECONDS=60
WEB3_JOB_MAX_ATTEMPTS=3

# Jito protected send
JITO_BUNDLE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_AUTH_TOKEN=

# Alerts
TELEGRAM_WEBHOOK_URL=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
WHITEHAT_ALERT_ADDRESSES=

# Shopier local package payments
SHOPIER_WEBHOOK_SECRET=

# Paddle global package payments
PADDLE_API_KEY=
PADDLE_ENV=production
PADDLE_WEBHOOK_SECRET=
PADDLE_STARTER_PRICE_ID=
PADDLE_PROFESSIONAL_PRICE_ID=
PADDLE_ENTERPRISE_PRICE_ID=
PADDLE_STARTER_PRODUCT_ID=
PADDLE_PROFESSIONAL_PRODUCT_ID=
PADDLE_ENTERPRISE_PRODUCT_ID=

# Legacy compatibility aliases; do not use for new installations.
CORS_ALLOWED_ORIGIN=
PADDLE_ENVIRONMENT=
PADDLE_BUILDER_PRICE_ID=
PADDLE_STUDIO_PRICE_ID=

# Pay-per-tool foundation remains disabled unless explicitly enabled.
KOSCHEI_X402_ENABLED=false
