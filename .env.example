# Application
PORT=10000
APP_ENV=production
STATIC_DIR=public
PUBLIC_APP_URL=https://tradepigloball.co
CORS_ORIGIN=https://tradepigloball.co,https://www.tradepigloball.co

# Required production security
# Generate strong, independent random values. Do not reuse database or provider credentials.
API_KEY_PEPPER=
USER_SESSION_SECRET=

# Neon Postgres
# Use the connection URL supported by the deployed driver and Neon configuration.
DATABASE_URL=
DATABASE_READ_URL=
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_SECONDS=1800

# Neon Auth
NEON_AUTH_BASE_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth
EXPO_PUBLIC_NEON_AUTH_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth
NEON_AUTH_ISSUER=https://YOUR_NEON_AUTH_HOST
NEON_AUTH_JWKS_URL=https://YOUR_NEON_AUTH_HOST/neondb/auth/.well-known/jwks.json
NEON_AUTH_STATE_SECRET=

# Owner access
OWNER_SECRET=
OWNER_WALLET=

# Legacy owner aliases; do not use for new installations.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Canonical Solana RPC
# ARVIS resolves one canonical SOLANA_RPC_URL at boot.
# Resolution priority:
# SOLANA_RPC_URL -> provider URL -> ALCHEMY_API_KEY -> public mainnet fallback.
SOLANA_RPC_URL=
ALCHEMY_SOLANA_RPC_URL=
HELIUS_SOLANA_RPC_URL=
QUICKNODE_SOLANA_RPC_URL=
ALCHEMY_API_KEY=
SOLANA_WSS_URL=
ALCHEMY_SOLANA_WSS_URL=
HELIUS_SOLANA_WSS_URL=
QUICKNODE_SOLANA_WSS_URL=
# Quota protection: production defaults to saver mode in code.
# Manual Safe Check, token scans and user-triggered reports stay live; background firehose workers pause unless forced.
SOLANA_RPC_LIMIT_SAVER_ENABLED=true
SOLANA_RPC_MIN_INTERVAL_MS=1500
SOLANA_RPC_MAX_429_RETRIES=0
SOLANA_RPC_429_BACKOFF_MS=2000
SOLANA_RPC_429_COOLDOWN_SECONDS=600
SOLANA_RPC_BUDGET_ENABLED=true
SOLANA_RPC_BUDGET_MAX_REQUESTS=220
SOLANA_RPC_BUDGET_WINDOW_SECONDS=3600
# JSON-RPC transaction-batch safety. Set false as an emergency provider-compatibility kill switch.
SOLANA_RPC_BATCH_ENABLED=true
SOLANA_RPC_TX_BATCH_SIZE=8
SOLANA_RPC_BATCH_COOLDOWN_SECONDS=600

# ARVIS live radar
# Keep background scanning off on small Alchemy quotas. Turn it on only after upgrading RPC capacity.
KOSCHEI_AUTOMATIC_SCANNING_ENABLED=false
# Explicit owner test mode: starts automatic workers and removes Koschei's local
# RPC and per-cycle report caps. Provider-side rate limits still apply. Off by default.
KOSCHEI_OWNER_UNLIMITED_AUTOSCAN_ENABLED=false
KOSCHEI_AUTO_RADAR_ENABLED=0
KOSCHEI_SOLANA_WATCH_MODE=manual
RADAR_STREAM_ENABLED=0
KOSCHEI_AUTO_RADAR_FORCE_BACKGROUND=false
RADAR_STREAM_FORCE_ENABLED=false
ARVIS_BACKGROUND_RPC_ENRICHMENT_ENABLED=false
ARVIS_HEARTBEAT_DISABLED=true
ARVIS_STREAM_VERDICT_DISABLED=true
ARVIS_HEARTBEAT_SECONDS=900
ARVIS_STREAM_VERDICT_SECONDS=300
KOSCHEI_RADAR_POLL_SECONDS=900
RAYDIUM_PROGRAM_ID=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8
PUMP_FUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# Selective automatic Pump Radar. Free PumpPortal discovery stays live in RPC saver mode;
# only mints whose aggregated 24h USD pair volume crosses the threshold receive full ARVIS RPC enrichment.
PUMPPORTAL_ENABLED=true
PUMPPORTAL_DATA_WS=wss://pumpportal.fun/api/data
PUMPPORTAL_API_KEY=
PUMP_HIGH_VOLUME_RADAR_ENABLED=true
PUMP_HIGH_VOLUME_MIN_24H_USD=500000
PUMP_HIGH_VOLUME_POLL_SECONDS=300
PUMP_HIGH_VOLUME_REPORT_COOLDOWN_SECONDS=21600
PUMP_HIGH_VOLUME_ATTEMPT_COOLDOWN_SECONDS=1800
PUMP_HIGH_VOLUME_CANDIDATE_PAGE_SIZE=900
PUMP_HIGH_VOLUME_MAX_REPORTS_PER_CYCLE=1

# Optional AI explanation layer
# AI explanations do not override evidence or signed verdicts.
TOGETHER_API_KEY=
TOGETHER_MODEL=
TOGETHER_AI_ENABLED=0

# Cache and jobs
CACHE_ENABLED=true
CACHE_KEY_PREFIX=koschei
REDIS_URL=
REDIS_TLS=false
NATS_URL=
NATS_SUBJECT_PREFIX=koschei.web3
WEB3_WORKER_ENABLED=false
WEB3_WORKER_CONCURRENCY=8
WEB3_JOB_TIMEOUT_SECONDS=60
WEB3_JOB_MAX_ATTEMPTS=3

# Jito protected send
JITO_BUNDLE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_AUTH_TOKEN=

# Alerts
TELEGRAM_WEBHOOK_URL=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
WHITEHAT_ALERT_ADDRESSES=

# KOSCH token payments and holder utility
KOSCH_TOKEN_MINT=HHPpU9u56Bwxov12nf7DXUCuv6h1q5j1xgGS3yukpump
KOSCHEI_TOKEN_MINT=HHPpU9u56Bwxov12nf7DXUCuv6h1q5j1xgGS3yukpump
KOSCH_TREASURY_WALLET=
KOSCHEI_TOKEN_NETWORK=solana-mainnet
# Holder utility is live by default in code. Set false only if you need to pause token-gated access.
KOSCHEI_TOKEN_GATE_ENABLED=true
# Any positive KOSCH balance unlocks basic Koschei utility after wallet verification.
KOSCHEI_TOKEN_TIER_BASIC=0.000001
KOSCHEI_TOKEN_TIER_PRO=250000
KOSCHEI_TOKEN_TIER_ENTERPRISE=2000000

# Legacy compatibility aliases; do not use for new installations.
CORS_ALLOWED_ORIGIN=

# Pay-per-tool foundation remains disabled unless explicitly enabled.
KOSCHEI_X402_ENABLED=false
# ARVIS holder tiered history depth
ARVIS_DEEP_SIG_LIMIT=100
ARVIS_DEEP_TX_PARSE=10
ARVIS_SHALLOW_SIG_LIMIT=20
ARVIS_SHALLOW_TX_PARSE=2
ARVIS_DEEP_OWNER_COUNT=8
ARVIS_SCAN_RPC_BUDGET=600


# Pump live trade capture and on-demand Launch Forensics
PUMPPORTAL_TRADE_SUBSCRIPTION_LIMIT=1000
ARVIS_ATA_SIG_LIMIT=50
ARVIS_ATA_MAX_PAGES=3
ARVIS_FUNDING_CHECK_COUNT=10
ARVIS_FUNDING_RPC_BUDGET=100
ARVIS_FUNDING_SIG_LIMIT=25
ARVIS_FUNDING_TX_PARSE=6
ARVIS_SNIPER_SLOT_WINDOW=3
ARVIS_TRADE_LEDGER_READ_LIMIT=20000
ARVIS_FORENSICS_TIMEOUT_SECONDS=120
