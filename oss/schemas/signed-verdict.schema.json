{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tradepigloball.co/schemas/signed-verdict.schema.json",
  "title": "Koschei Deterministic Verdict",
  "description": "Evidence-backed, rule-based verdict contract. No weighted or 0-100 risk score is part of this contract.",
  "type": "object",
  "required": [
    "grade",
    "evidence",
    "rule_version",
    "signed"
  ],
  "properties": {
    "target": { "type": "string", "minLength": 1 },
    "network": { "type": "string", "default": "solana-mainnet" },
    "grade": {
      "type": "string",
      "pattern": "^[A-F-]$",
      "description": "'-' means no grade-changing rule was triggered; absence of evidence is not an A grade."
    },
    "verdict": { "type": "string" },
    "recommendation": { "type": "string" },
    "evidence": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "triggered_rules": {
      "type": "array",
      "description": "Deterministic rules that changed or constrained the verdict.",
      "items": {
        "type": "object",
        "required": ["rule_id", "evidence_status"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "tier": { "type": "string" },
          "evidence_status": {
            "type": "string",
            "enum": ["verified", "observed", "inferred", "unverified"]
          },
          "grade_effect": { "type": "string" },
          "summary": { "type": "string" },
          "evidence_keys": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "signatures": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "decision_path": {
      "type": "array",
      "description": "Human-auditable deterministic decision steps in evaluation order.",
      "items": { "type": "string", "minLength": 1 }
    },
    "rule_version": { "type": "string", "minLength": 1 },
    "signed": {
      "type": "boolean",
      "description": "False is valid for a no-grade result; consumers must withhold policy actions that require a cryptographic signature."
    },
    "signature": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "signed": { "const": true } },
        "required": ["signed"]
      },
      "then": { "required": ["signature"] }
    }
  ],
  "additionalProperties": true
}
