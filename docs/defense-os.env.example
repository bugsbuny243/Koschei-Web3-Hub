# Defense Agent Runtime: attaches read-only shadow results to Unified Investigation.
KOSCHEI_DEFENSE_AGENT_RUNTIME_ENABLED=false

# Optional Together embeddings for the versioned knowledge corpus.
KOSCHEI_DEFENSE_KNOWLEDGE_EMBEDDINGS_ENABLED=false
TOGETHER_MODEL_EMBEDDING=BAAI/bge-large-en-v1.5

# Bounded public GitHub source import pinned to an exact commit SHA.
# This downloads source only; it does not execute, build or deploy it.
KOSCHEI_DEFENSE_SOURCE_IMPORT_ENABLED=false

# Review-only AI patch proposal. Does not apply a patch or change a verdict.
KOSCHEI_DEFENSE_PATCH_PROPOSAL_ENABLED=false
TOGETHER_MODEL_DEFENSE_ENGINEER=

# Local ephemeral source-bundle command runner. Keep false in the web container.
# Enable only on a separately isolated Railway worker with no wallet/private-key access.
KOSCHEI_DEFENSE_SANDBOX_ENABLED=false

# Existing Together provider key is reused through internal/router.
TOGETHER_API_KEY=
