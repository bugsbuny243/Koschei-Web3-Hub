# Railway web service: read-only Defense Agent shadow results.
KOSCHEI_DEFENSE_AGENT_RUNTIME_ENABLED=false

# Optional Together embeddings for the versioned knowledge corpus.
KOSCHEI_DEFENSE_KNOWLEDGE_EMBEDDINGS_ENABLED=false
TOGETHER_MODEL_EMBEDDING=BAAI/bge-large-en-v1.5

# Bounded public GitHub source import pinned to an exact commit SHA.
KOSCHEI_DEFENSE_SOURCE_IMPORT_ENABLED=false

# Deterministic Anchor IDL harness planning. Plans never execute source.
KOSCHEI_DEFENSE_HARNESS_PLANNER_ENABLED=false

# Phase 12A owner-only immutable execution-profile gate.
# This does not execute or enqueue a harness.
KOSCHEI_DEFENSE_HARNESS_EXECUTION_GATE_ENABLED=false

# Phase 12B deterministic offline harness materialization.
# This normalizes an owner-prepared bundle; it does not resolve dependencies or execute source.
KOSCHEI_DEFENSE_HARNESS_MATERIALIZATION_ENABLED=false

# Web-service gate for enqueueing jobs to a separate Railway Defense Worker.
KOSCHEI_DEFENSE_WORKER_QUEUE_ENABLED=false

# Versioned paired reproduction workflow on the Railway web service.
KOSCHEI_DEFENSE_REPRODUCTION_ENABLED=false

# Program sentinel owner-management gate on the Railway web service.
KOSCHEI_DEFENSE_SENTINEL_MANAGEMENT_ENABLED=false

# Railway Defense Worker service only.
KOSCHEI_DEFENSE_WORKER_ENABLED=false
KOSCHEI_DEFENSE_WORKER_ID=
# Required for Phase 12 pinning. Must be an immutable sha256 image digest,
# not a mutable tag, branch name or deployment label.
KOSCHEI_DEFENSE_WORKER_IMAGE_DIGEST=
KOSCHEI_DEFENSE_WORKER_POLL_SECONDS=2
KOSCHEI_DEFENSE_WORKER_JOB_TIMEOUT_SECONDS=900

# Separate Railway program sentinel service only.
KOSCHEI_DEFENSE_SENTINEL_ENABLED=false
KOSCHEI_DEFENSE_SENTINEL_ID=
KOSCHEI_DEFENSE_SENTINEL_POLL_SECONDS=10
KOSCHEI_DEFENSE_SENTINEL_CHECK_TIMEOUT_SECONDS=45

# Review-only AI patch proposal. Does not apply a patch or change a verdict.
KOSCHEI_DEFENSE_PATCH_PROPOSAL_ENABLED=false
TOGETHER_MODEL_DEFENSE_ENGINEER=

# Local ephemeral source-bundle command runner.
# Keep false in the Railway web service. Set true only in the isolated Railway worker.
KOSCHEI_DEFENSE_SANDBOX_ENABLED=false

# Existing Together provider key is reused through internal/router.
TOGETHER_API_KEY=
