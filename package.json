{
  "name": "koscei-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Base Sepolia bridge smart contract and custodial wallet development environment",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "lint": "eslint .",
    "node": "hardhat node",
